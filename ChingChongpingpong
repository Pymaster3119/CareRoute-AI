<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CareRootAI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
:root {
  --bg: #FBF7F1;
  --surface: #FFFFFF;
  --ink: #1F2A29;
  --ink-soft: #5C6B69;
  --teal: #0F5C56;
  --teal-soft: #DCEDEA;
  --coral: #E0694D;
  --coral-soft: #FBE6E0;
  --line: #E6DFD3;
  --radius: 14px;
  --shadow: 0 2px 10px rgba(15, 92, 86, 0.06);
  --font-display: "Fraunces", Georgia, serif;
  --font-body: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

a { color: var(--teal); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ---------- Top nav ---------- */
.topnav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  background: var(--surface);
  border-bottom: 1px solid var(--line);
  position: sticky;
  top: 0;
  z-index: 10;
}
.topnav .brand {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.25rem;
  color: var(--teal);
  letter-spacing: 0.01em;
}
.topnav .brand span { color: var(--coral); }
.topnav nav { display: flex; gap: 20px; align-items: center; }
.topnav nav a {
  color: var(--ink-soft);
  font-size: 0.92rem;
  font-weight: 500;
  cursor: pointer;
}
.topnav nav a.active { color: var(--teal); }
.topnav nav a:hover { color: var(--teal); text-decoration: none; }

/* ---------- Page shell ---------- */
.page { max-width: 720px; margin: 0 auto; padding: 36px 20px 64px; }
.page-wide { max-width: 920px; margin: 0 auto; padding: 36px 20px 64px; }

.eyebrow {
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--coral);
  font-weight: 600;
  margin: 0 0 6px;
}
h1.page-title {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 600;
  margin: 0 0 8px;
  color: var(--ink);
}
.page-sub { color: var(--ink-soft); font-size: 0.98rem; margin: 0 0 28px; }

/* ---------- Cards / forms ---------- */
.card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 28px;
}
.field { margin-bottom: 20px; }
.field label { display: block; font-size: 0.88rem; font-weight: 600; margin-bottom: 6px; color: var(--ink); }
.field .hint { font-size: 0.8rem; color: var(--ink-soft); margin-top: 4px; }

input[type="text"], input[type="email"], input[type="password"], select, textarea {
  width: 100%;
  padding: 11px 13px;
  font-size: 0.95rem;
  font-family: var(--font-body);
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--bg);
  color: var(--ink);
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}
input:focus, select:focus, textarea:focus {
  outline: none;
  border-color: var(--teal);
  box-shadow: 0 0 0 3px var(--teal-soft);
}
textarea { resize: vertical; min-height: 90px; }

/* ---------- File / image upload zone ---------- */
.upload-zone {
  border: 1.5px dashed var(--line);
  border-radius: 12px;
  background: var(--bg);
  padding: 28px 16px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.15s ease, background 0.15s ease;
  position: relative;
}
.upload-zone:hover, .upload-zone.dragover { border-color: var(--teal); background: var(--teal-soft); }
.upload-zone input[type="file"] {
  position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer;
}
.upload-zone .upload-icon { font-size: 1.8rem; margin-bottom: 8px; display: block; }
.upload-zone .upload-title { font-weight: 600; font-size: 0.95rem; margin-bottom: 2px; }
.upload-zone .upload-sub { font-size: 0.82rem; color: var(--ink-soft); }

.preview-wrap { margin-top: 14px; display: none; }
.preview-wrap.show { display: block; }
.preview-wrap img {
  max-width: 100%; max-height: 260px; border-radius: 10px;
  border: 1px solid var(--line); display: block; margin: 0 auto;
}
.preview-filename { font-size: 0.82rem; color: var(--ink-soft); text-align: center; margin-top: 8px; }

/* ---------- Buttons ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px 22px;
  border-radius: 10px;
  border: none;
  font-size: 0.95rem;
  font-weight: 600;
  font-family: var(--font-body);
  cursor: pointer;
  transition: background 0.15s ease, transform 0.05s ease;
  text-decoration: none;
}
.btn-primary { background: var(--teal); color: #fff; width: 100%; }
.btn-primary:hover { background: #0c4a45; }
.btn-secondary { background: var(--surface); color: var(--teal); border: 1px solid var(--teal); }
.btn-secondary:hover { background: var(--teal-soft); }
.btn:active { transform: scale(0.99); }

.form-footer { margin-top: 22px; text-align: center; font-size: 0.88rem; color: var(--ink-soft); }

/* ---------- Step nav (prev/next) ---------- */
.step-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 22px;
  gap: 12px;
}
.step-nav .spacer { flex: 1; }
.step-dots {
  display: flex;
  gap: 6px;
  justify-content: center;
  margin: 18px 0 0;
}
.step-dots .dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--line);
  cursor: pointer;
  transition: background 0.15s ease;
}
.step-dots .dot.active { background: var(--teal); }

/* ---------- Feed ---------- */
.feed-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24px; gap: 12px; flex-wrap: wrap;
}
.filter-bar { display: flex; gap: 8px; flex-wrap: wrap; }
.chip {
  border: 1px solid var(--line);
  background: var(--surface);
  border-radius: 999px;
  padding: 6px 14px;
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--ink-soft);
  cursor: pointer;
  transition: all 0.15s ease;
}
.chip.active, .chip:hover { border-color: var(--teal); color: var(--teal); background: var(--teal-soft); }

.post-card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 20px 22px;
  margin-bottom: 16px;
}
.post-head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.avatar {
  width: 42px; height: 42px; border-radius: 50%;
  background: var(--teal-soft); color: var(--teal);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-family: var(--font-display); font-size: 1rem; flex-shrink: 0;
}
.avatar.coral { background: var(--coral-soft); color: var(--coral); }
.post-meta { flex: 1; min-width: 0; }
.post-name { font-weight: 600; font-size: 0.95rem; display: flex; align-items: center; gap: 6px; }
.post-name .badge {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
  background: var(--teal); color: #fff; padding: 2px 7px; border-radius: 5px;
}
.post-sub { font-size: 0.8rem; color: var(--ink-soft); }
.post-time { font-size: 0.78rem; color: var(--ink-soft); white-space: nowrap; }
.post-body { font-size: 0.95rem; margin-bottom: 12px; }
.post-image { width: 100%; border-radius: 10px; border: 1px solid var(--line); margin-bottom: 12px; display: block; }
.post-actions { display: flex; gap: 18px; border-top: 1px solid var(--line); padding-top: 12px; }
.post-actions button {
  background: none; border: none; color: var(--ink-soft); font-size: 0.85rem; font-weight: 500;
  cursor: pointer; display: flex; align-items: center; gap: 6px; padding: 0; font-family: var(--font-body);
}
.post-actions button:hover { color: var(--teal); }

.status-box {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 16px 20px;
  margin-bottom: 24px;
}
.status-box textarea { border: none; padding: 6px 0; font-size: 0.98rem; }
.status-box textarea:focus { box-shadow: none; }
.status-box-actions {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 8px; border-top: 1px solid var(--line); padding-top: 12px;
}
.status-box-actions .left-tools { display: flex; gap: 14px; color: var(--ink-soft); font-size: 0.85rem; }
.status-box-actions .btn { width: auto; padding: 9px 20px; }

/* ---------- Page switching ---------- */
.app-page { display: none; }
.app-page.active { display: block; }

@media (max-width: 600px) {
  .page, .page-wide { padding: 24px 14px 48px; }
  .card { padding: 20px; }
  .topnav nav { gap: 12px; }
}
  </style>
</head>
<body>

  <header class="topnav">
    <div class="brand">Support<span>Path</span></div>
    <nav>
      <a data-goto="upload" class="nav-link active">Upload</a>
      <a data-goto="register-user" class="nav-link">Sign up</a>
      <a data-goto="register-doctor" class="nav-link">For doctors</a>
      <a data-goto="feed-doctor" class="nav-link">Doctor feed</a>
      <a data-goto="feed-status" class="nav-link">Community</a>
    </nav>
  </header>

  <!-- ============ PAGE 1: UPLOAD ============ -->
  <main class="page app-page active" id="page-upload">
    <p class="eyebrow">Step 1 of 5</p>
    <h1 class="page-title">Upload your document</h1>
    <p class="page-sub">Add a photo or PDF of the letter, form, or notice you received. We'll turn it into a clear summary and checklist.</p>

    <div class="card">
      <form id="upload-form">
        <div class="field">
          <label for="doc-file">Document image or PDF</label>
          <div class="upload-zone" id="upload-zone">
            <span class="upload-icon">📄</span>
            <div class="upload-title">Drop a file here or click to browse</div>
            <div class="upload-sub">JPG, PNG, or PDF — up to 10MB</div>
            <input type="file" id="doc-file" name="doc-file" accept="image/*,.pdf" />
          </div>
          <div class="preview-wrap" id="preview-wrap">
            <img id="preview-img" alt="Preview of uploaded document" />
            <div class="preview-filename" id="preview-filename"></div>
          </div>
        </div>

        <div class="field">
          <label for="doc-caption">Tell us a bit about this document</label>
          <textarea id="doc-caption" name="doc-caption" placeholder="Example: This is a letter from my child's school about a meeting next week. I'm not sure if I need to do anything."></textarea>
          <div class="hint">Optional, but it helps us focus the summary on what matters to you.</div>
        </div>

        <div class="step-nav">
          <div class="spacer"></div>
          <button type="submit" class="btn btn-primary">Continue →</button>
        </div>
      </form>
    </div>

    <div class="step-dots">
      <div class="dot active" data-goto="upload"></div>
      <div class="dot" data-goto="register-user"></div>
      <div class="dot" data-goto="register-doctor"></div>
      <div class="dot" data-goto="feed-doctor"></div>
      <div class="dot" data-goto="feed-status"></div>
    </div>
  </main>

  <!-- ============ PAGE 2: USER REGISTRATION ============ -->
  <main class="page app-page" id="page-register-user">
    <p class="eyebrow">Step 2 of 5</p>
    <h1 class="page-title">Create your account</h1>
    <p class="page-sub">Save your documents, track action items, and connect with your community.</p>

    <div class="card">
      <form id="user-form">
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="janedoe" required />
        </div>

        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="At least 8 characters" required minlength="8" />
        </div>

        <div class="field">
          <label for="location">Location</label>
          <input type="text" id="location" name="location" placeholder="City, State" required />
          <div class="hint">Used to connect you with local resources and community members.</div>
        </div>

        <div class="step-nav">
          <button type="button" class="btn btn-secondary nav-link" data-goto="upload">← Back</button>
          <button type="submit" class="btn btn-primary">Continue →</button>
        </div>
      </form>
    </div>

    <div class="step-dots">
      <div class="dot" data-goto="upload"></div>
      <div class="dot active" data-goto="register-user"></div>
      <div class="dot" data-goto="register-doctor"></div>
      <div class="dot" data-goto="feed-doctor"></div>
      <div class="dot" data-goto="feed-status"></div>
    </div>
  </main>

  <!-- ============ PAGE 3: DOCTOR REGISTRATION ============ -->
  <main class="page app-page" id="page-register-doctor">
    <p class="eyebrow">Step 3 of 5</p>
    <h1 class="page-title">Register as a doctor</h1>
    <p class="page-sub">Join our verified provider network to share guidance with the community. Verification typically takes 1–2 business days.</p>

    <div class="card">
      <form id="doctor-form">
        <div class="field">
          <label for="doc-name">Full name</label>
          <input type="text" id="doc-name" name="doc-name" placeholder="Dr. Maria Chen" required />
        </div>

        <div class="field">
          <label for="doc-password">Password</label>
          <input type="password" id="doc-password" name="doc-password" placeholder="At least 8 characters" required minlength="8" />
        </div>

        <div class="field">
          <label for="doc-specialty">Specialty</label>
          <select id="doc-specialty" name="doc-specialty" required>
            <option value="" disabled selected>Select a specialty</option>
            <option>Family Medicine</option>
            <option>Internal Medicine</option>
            <option>Pediatrics</option>
            <option>Psychiatry</option>
            <option>OB/GYN</option>
            <option>Cardiology</option>
            <option>Dermatology</option>
            <option>Other</option>
          </select>
        </div>

        <div class="field">
          <label for="doc-email">Email address</label>
          <input type="email" id="doc-email" name="doc-email" placeholder="you@hospital.org" required />
        </div>

        <div class="field">
          <label for="doc-workplace">Workplace</label>
          <input type="text" id="doc-workplace" name="doc-workplace" placeholder="Hospital, clinic, or practice name" required />
        </div>

        <div class="field">
          <label for="doc-degree">Degree or license (image)</label>
          <div class="upload-zone" id="degree-zone">
            <span class="upload-icon">🎓</span>
            <div class="upload-title">Upload a photo of your degree or license</div>
            <div class="upload-sub">JPG or PNG — used for verification only</div>
            <input type="file" id="doc-degree" name="doc-degree" accept="image/*" required />
          </div>
          <div class="preview-wrap" id="degree-preview-wrap">
            <img id="degree-preview-img" alt="Preview of uploaded degree" />
            <div class="preview-filename" id="degree-preview-filename"></div>
          </div>
        </div>

        <div class="step-nav">
          <button type="button" class="btn btn-secondary nav-link" data-goto="register-user">← Back</button>
          <button type="submit" class="btn btn-primary">Continue →</button>
        </div>
      </form>
    </div>

    <div class="step-dots">
      <div class="dot" data-goto="upload"></div>
      <div class="dot" data-goto="register-user"></div>
      <div class="dot active" data-goto="register-doctor"></div>
      <div class="dot" data-goto="feed-doctor"></div>
      <div class="dot" data-goto="feed-status"></div>
    </div>
  </main>

  <!-- ============ PAGE 4: DOCTOR FEED ============ -->
  <main class="page-wide app-page" id="page-feed-doctor">
    <p class="eyebrow">Step 4 of 5 · Verified providers</p>
    <h1 class="page-title">Doctor feed</h1>
    <p class="page-sub">Guidance, explainers, and answers from verified medical professionals.</p>

    <div class="feed-header">
      <div class="filter-bar">
        <div class="chip active">All</div>
        <div class="chip">Family Medicine</div>
        <div class="chip">Pediatrics</div>
        <div class="chip">Psychiatry</div>
        <div class="chip">Cardiology</div>
      </div>
    </div>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar">MC</div>
        <div class="post-meta">
          <div class="post-name">Dr. Maria Chen <span class="badge">Verified</span></div>
          <div class="post-sub">Family Medicine · Lakeview Medical Group</div>
        </div>
        <div class="post-time">2h ago</div>
      </div>
      <div class="post-body">
        If your discharge papers say "follow up in 7–10 days," that's a real deadline, not a suggestion. Missing it is one of the most common reasons people end up back in the ER. If you're not sure who to call, your primary care office can usually fit you in for a short follow-up visit.
      </div>
      <div class="post-actions">
        <button>👍 128</button>
        <button>💬 14 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar coral">RP</div>
        <div class="post-meta">
          <div class="post-name">Dr. Raj Patel <span class="badge">Verified</span></div>
          <div class="post-sub">Pediatrics · Sunrise Children's Clinic</div>
        </div>
        <div class="post-time">5h ago</div>
      </div>
      <div class="post-body">
        Quick tip for parents: school immunization notices usually give you a 30-day grace period, but the letter doesn't always say that clearly. If your child is missing one vaccine, call your pediatrician's office — most can get you an appointment before the deadline.
      </div>
      <img class="post-image" src="https://images.unsplash.com/photo-1632053002469-d8a0e88e1f96?w=900&q=60" alt="A pediatrician's office waiting room" />
      <div class="post-actions">
        <button>👍 96</button>
        <button>💬 8 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar">SK</div>
        <div class="post-meta">
          <div class="post-name">Dr. Sarah Kim <span class="badge">Verified</span></div>
          <div class="post-sub">Internal Medicine · Brightside Health</div>
        </div>
        <div class="post-time">1d ago</div>
      </div>
      <div class="post-body">
        Insurance "Explanation of Benefits" letters often say "This Is Not A Bill" in large letters — but they can still mention an amount you owe. The actual bill comes separately from the provider. If the numbers don't match what you expected, call the number on the EOB before paying anything.
      </div>
      <div class="post-actions">
        <button>👍 211</button>
        <button>💬 32 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <div class="step-nav">
      <button type="button" class="btn btn-secondary nav-link" data-goto="register-doctor">← Back</button>
      <button type="button" class="btn btn-primary nav-link" data-goto="feed-status">Continue →</button>
    </div>

    <div class="step-dots">
      <div class="dot" data-goto="upload"></div>
      <div class="dot" data-goto="register-user"></div>
      <div class="dot" data-goto="register-doctor"></div>
      <div class="dot active" data-goto="feed-doctor"></div>
      <div class="dot" data-goto="feed-status"></div>
    </div>
  </main>

  <!-- ============ PAGE 5: COMMUNITY / STATUS FEED ============ -->
  <main class="page app-page" id="page-feed-status">
    <p class="eyebrow">Step 5 of 5 · Your neighborhood</p>
    <h1 class="page-title">Community feed</h1>
    <p class="page-sub">See what others nearby are dealing with, and share what helped you.</p>

    <div class="status-box">
      <textarea placeholder="Share an update, ask a question, or post what you learned..." rows="2"></textarea>
      <div class="status-box-actions">
        <div class="left-tools">
          <span>📷 Photo</span>
          <span>📍 Location</span>
        </div>
        <button class="btn btn-primary">Post</button>
      </div>
    </div>

    <div class="filter-bar" style="margin-bottom: 20px;">
      <div class="chip active">All</div>
      <div class="chip">Housing</div>
      <div class="chip">Health</div>
      <div class="chip">School</div>
      <div class="chip">Benefits</div>
    </div>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar coral">JT</div>
        <div class="post-meta">
          <div class="post-name">Jamie T.</div>
          <div class="post-sub">Fairfield, NJ</div>
        </div>
        <div class="post-time">35m ago</div>
      </div>
      <div class="post-body">
        Got a letter from my landlord about a "notice to cure" — totally panicked at first. Uploaded it here and found out it was just about a broken smoke detector, not an eviction. Fixed it same day. Such a relief.
      </div>
      <div class="post-actions">
        <button>👍 22</button>
        <button>💬 5 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar">AM</div>
        <div class="post-meta">
          <div class="post-name">Aisha M.</div>
          <div class="post-sub">Newark, NJ</div>
        </div>
        <div class="post-time">2h ago</div>
      </div>
      <div class="post-body">
        Does anyone know what "verification of income" means on a FAFSA notice? My summary said I need to send pay stubs but didn't say which months. Calling the financial aid office tomorrow but wanted to see if others ran into this.
      </div>
      <div class="post-actions">
        <button>👍 9</button>
        <button>💬 11 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <article class="post-card">
      <div class="post-head">
        <div class="avatar coral">DL</div>
        <div class="post-meta">
          <div class="post-name">Diego L.</div>
          <div class="post-sub">Paterson, NJ</div>
        </div>
        <div class="post-time">6h ago</div>
      </div>
      <div class="post-body">
        Discharge papers said "follow up in 7 days" but I had no idea who to call. The checklist found the clinic phone number printed at the bottom of page 2 — I never would've noticed it. Appointment booked for Thursday.
      </div>
      <img class="post-image" src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=900&q=60" alt="A hand holding a printed medical discharge document" />
      <div class="post-actions">
        <button>👍 47</button>
        <button>💬 6 comments</button>
        <button>↗ Share</button>
      </div>
    </article>

    <div class="step-nav">
      <button type="button" class="btn btn-secondary nav-link" data-goto="feed-doctor">← Back</button>
      <button type="button" class="btn btn-primary nav-link" data-goto="upload">Start over ↺</button>
    </div>

    <div class="step-dots">
      <div class="dot" data-goto="upload"></div>
      <div class="dot" data-goto="register-user"></div>
      <div class="dot" data-goto="register-doctor"></div>
      <div class="dot" data-goto="feed-doctor"></div>
      <div class="dot active" data-goto="feed-status"></div>
    </div>
  </main>

  <script>
    // ---------- PAGE SWITCHING ----------
    function goTo(pageId) {
      document.querySelectorAll('.app-page').forEach(p => p.classList.remove('active'));
      document.getElementById('page-' + pageId).classList.add('active');

      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.toggle('active', link.dataset.goto === pageId);
      });
      document.querySelectorAll('.dot').forEach(dot => {
        dot.classList.toggle('active', dot.dataset.goto === pageId);
      });

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.querySelectorAll('[data-goto]').forEach(el => {
      el.addEventListener('click', () => goTo(el.dataset.goto));
    });

    // ---------- UPLOAD PREVIEW ----------
    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('doc-file');
    const previewWrap = document.getElementById('preview-wrap');
    const previewImg = document.getElementById('preview-img');
    const previewFilename = document.getElementById('preview-filename');

    fileInput.addEventListener('change', handleFile);

    ['dragover', 'dragleave', 'drop'].forEach(evt => {
      uploadZone.addEventListener(evt, e => {
        e.preventDefault();
        if (evt === 'dragover') uploadZone.classList.add('dragover');
        if (evt === 'dragleave' || evt === 'drop') uploadZone.classList.remove('dragover');
        if (evt === 'drop' && e.dataTransfer.files.length) {
          fileInput.files = e.dataTransfer.files;
          handleFile();
        }
      });
    });

    function handleFile() {
      const file = fileInput.files[0];
      if (!file) return;
      previewFilename.textContent = file.name;
      if (file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = e => {
          previewImg.src = e.target.result;
          previewImg.style.display = 'block';
          previewWrap.classList.add('show');
        };
        reader.readAsDataURL(file);
      } else {
        previewImg.style.display = 'none';
        previewWrap.classList.add('show');
      }
    }

    // ---------- DOCTOR DEGREE PREVIEW ----------
    const degreeInput = document.getElementById('doc-degree');
    const degreePreviewWrap = document.getElementById('degree-preview-wrap');
    const degreePreviewImg = document.getElementById('degree-preview-img');
    const degreePreviewFilename = document.getElementById('degree-preview-filename');

    degreeInput.addEventListener('change', () => {
      const file = degreeInput.files[0];
      if (!file) return;
      degreePreviewFilename.textContent = file.name;
      const reader = new FileReader();
      reader.onload = e => {
        degreePreviewImg.src = e.target.result;
        degreePreviewWrap.classList.add('show');
      };
      reader.readAsDataURL(file);
    });

    // ---------- FORM SUBMITS -> GO TO NEXT PAGE ----------
    document.getElementById('upload-form').addEventListener('submit', e => {
      e.preventDefault();
      goTo('register-user');
    });

    document.getElementById('user-form').addEventListener('submit', e => {
      e.preventDefault();
      goTo('register-doctor');
    });

    document.getElementById('doctor-form').addEventListener('submit', e => {
      e.preventDefault();
      goTo('feed-doctor');
    });
  </script>

</body>
</html>
